# ── Discord ─────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=
# Application (client) ID — same page, "General Information"
DISCORD_CLIENT_ID=
# Guild ID to register slash commands to instantly (dev). Leave empty for
# global registration (can take up to 1h to propagate).
DISCORD_GUILD_ID=

# ── go-librespot ────────────────────────────────────────────────────────
# Name shown as the speaker in the Spotify app device list.
LIBRESPOT_DEVICE_NAME=Andrzej Śpiewacz
# Path to the go-librespot binary (run `npm run install:librespot` to fetch it).
LIBRESPOT_BIN=./bin/go-librespot
# HTTP API the daemon exposes (must match config/go-librespot.yml).
LIBRESPOT_API_HOST=127.0.0.1
LIBRESPOT_API_PORT=3678
# Named pipe the daemon writes raw PCM into. Created automatically.
LIBRESPOT_FIFO=/tmp/andrzej-spiewacz.fifo
# Streaming bitrate: 96, 160 or 320 (Premium required for 320).
LIBRESPOT_BITRATE=320

# Auth mode:
#   interactive — OAuth once per user (`/link` in Discord + the link portal
#                 below), then their device is reachable from ANY network via
#                 Spotify's servers. Use this for a remote/headless host. (default)
#   zeroconf    — LAN-only discovery via mDNS; the bot host and your Spotify
#                 app must be on the same local network.
LIBRESPOT_AUTH=interactive
# Loopback port for the interactive OAuth redirect (http://127.0.0.1:<port>/login).
# Purely internal — the bot process calls its own child go-librespot daemon on
# this port, so it never needs SSH-forwarding or a published Docker port.
# Each user's permanent device index N uses CALLBACK_PORT + N (38080, 38081, …).
LIBRESPOT_CALLBACK_PORT=38080

# Independent players, one per Discord user. Each Spotify Connect device is
# backed by a SEPARATE Spotify Premium account (one account = one simultaneous
# stream), so multiple people can stream DIFFERENT music at the same time. The
# first time someone runs /link (or /join), the bot permanently assigns them
# the next device index (persisted in state/registry.json) and shows up as
# "<name> #N+1"; that index's API port, OAuth callback port, FIFO and
# credentials are auto-offset by N so nothing collides. There's no player-count
# to set here — capacity isn't a fixed pool, it grows with however many people
# have linked.

# ── Web control / auth panel ────────────────────────────────────────────
# Dark dashboard showing auth status, the Spotify authorize link, now-playing,
# and every guild currently streaming. Set to false to disable it entirely.
PANEL_ENABLED=true
# Bind address. Loopback by default for safety — SSH-tunnel it for remote use:
#   ssh -L 8077:127.0.0.1:8077 user@server   →   open http://127.0.0.1:8077
PANEL_HOST=127.0.0.1
PANEL_PORT=8077

# ── Link portal (replaces /code) ────────────────────────────────────────
# Small public web page where a user finishes Spotify OAuth (pastes the
# redirected 127.0.0.1 URL) after running /link, and sees their own linked
# status afterward. Set to false to disable it entirely.
LINK_PORTAL_ENABLED=true
# Binds all interfaces by default (unlike the admin panel above) — this is
# meant to sit behind YOUR OWN reverse proxy / HTTPS termination, which is what
# should actually be exposed to the internet.
LINK_PORTAL_HOST=0.0.0.0
LINK_PORTAL_PORT=8078
# Public HTTPS origin your reverse proxy serves this on, e.g.:
#   LINK_PORTAL_BASE_URL=https://spiewacz.scplegion.ovh
# Required for /link to produce a working link — leave empty to disable /link.
LINK_PORTAL_BASE_URL=

# ── Spotify token experiment (scripts/test-spotify-token.mjs) ───────────
# NOT used by the running bot — only by the one-off diagnostic script that
# checks whether a token from our OWN Spotify app (not go-librespot's built-in
# client) can authenticate a real Connect session. Only set these if you're
# running that script; register the app at https://developer.spotify.com/dashboard
# with SPOTIFY_REDIRECT_URI as its exact redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://spiewacz.scplegion.ovh/callback

# ── Karaoke (/lyrics) ───────────────────────────────────────────────────
# Milliseconds the heard audio lags go-librespot's decode position (FIFO +
# ffmpeg + Discord jitter buffer). Subtracted from the playback clock so the
# highlighted lyric line matches what listeners actually hear. Raise it if
# lyrics run AHEAD of the audio, lower it if they trail BEHIND. Can also be
# nudged live per board with `/lyrics offset:<ms>`.
KARAOKE_SYNC_OFFSET_MS=1000
